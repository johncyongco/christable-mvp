# Production Environment Variables
# Copy this to .env.production.local for local testing
# Or set these in your deployment platform (Vercel, etc.)

# Database (Required for production)
DATABASE_URL="postgresql://username:password@host:5432/database"

# Next.js Authentication (Required)
NEXTAUTH_SECRET="generate-a-secure-random-string-here"
NEXTAUTH_URL="https://your-domain.com"

# App URL (Required)
APP_URL="https://your-domain.com"

# Optional - Set to mock values for testing without external services
FIREBASE_PROJECT_ID="mock-project-id"
FIREBASE_PRIVATE_KEY="mock-private-key"
FIREBASE_CLIENT_EMAIL="mock-client-email"

GOOGLE_SHEETS_CLIENT_EMAIL="mock-service-account-email"
GOOGLE_SHEETS_PRIVATE_KEY="mock-private-key"
GOOGLE_SHEETS_SPREADSHEET_ID="mock-spreadsheet-id"

SLACK_BOT_TOKEN="xoxb-mock-bot-token"
SLACK_SIGNING_SECRET="mock-signing-secret"

N8N_WEBHOOK_URL="https://mock-n8n-instance.com/webhook/mock-path"
N8N_API_KEY="mock-n8n-api-key"

# Note: For testing, you can use mock values for all optional variables
# The application will work in demo mode without external integrations