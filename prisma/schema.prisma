generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id              String    @id @default(uuid())
  userId          String?   @unique // External user identifier
  name            String
  role            String?
  phone           String?
  email           String?   @unique
  messageNotes    String?
  status          String    @default("active") // active, inactive, away
  slackChannelId  String?
  imageUrl        String?
  lastPingAt      DateTime?
  lastMessageAt   DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  source          String    @default("APP") // APP, SHEETS, SLACK, N8N
  
  // Relations
  teamId          String?
  team            Team?     @relation(fields: [teamId], references: [id])
  zoneId          String?
  zone            Zone?     @relation(fields: [zoneId], references: [id])
  
  // Back relations
  pings           Ping[]
  events          Event[]
  schedules       Schedule[]

  // Indexes
  @@index([teamId])
  @@index([zoneId])
  @@index([status])
  @@index([updatedAt])
}

model Team {
  id          String    @id @default(uuid())
  name        String
  description String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  source      String    @default("APP")
  
  // Relations
  users       User[]
  pings       Ping[]
  events      Event[]
  schedules   Schedule[]
}

model Zone {
  id          String    @id @default(uuid())
  name        String
  label       String?
  polygonData Json      // { type: "Polygon", coordinates: [[[x1,y1], [x2,y2], ...]] }
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  
  // Relations
  venueMapId  String
  venueMap    VenueMap  @relation(fields: [venueMapId], references: [id])
  users       User[]
  schedules   Schedule[]
  events      Event[]
}

model VenueMap {
  id          String    @id @default(uuid())
  name        String
  imageUrl    String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  
  // Relations
  zones       Zone[]
}

model Schedule {
  id              String    @id @default(uuid())
  title           String
  description     String?
  scheduledTime   DateTime
  reminderMinutes Int?      @default(15) // Minutes before to send reminder
  status          String    @default("pending") // pending, active, completed, cancelled
  messageTemplate String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  source          String    @default("APP")
  
  // Relations
  teamId          String?
  team            Team?     @relation(fields: [teamId], references: [id])
  zoneId          String?
  zone            Zone?     @relation(fields: [zoneId], references: [id])
  userId          String?
  user            User?     @relation(fields: [userId], references: [id])
  events          Event[]

  // Indexes
  @@index([scheduledTime])
  @@index([status])
  @@index([teamId])
  @@index([zoneId])
}

model Event {
  id            String    @id @default(uuid())
  type          String    // ping_sent, team_ping_expanded, slack_received, schedule_triggered, sheets_sync, user_updated, team_updated, zone_updated
  source        String    @default("APP") // APP, SHEETS, SLACK, N8N, SYSTEM
  payload       Json      // { message: string, metadata: any }
  createdAt     DateTime  @default(now())
  
  // Optional relations
  userId        String?
  user          User?     @relation(fields: [userId], references: [id])
  teamId        String?
  team          Team?     @relation(fields: [teamId], references: [id])
  zoneId        String?
  zone          Zone?     @relation(fields: [zoneId], references: [id])
  scheduleId    String?
  schedule      Schedule? @relation(fields: [scheduleId], references: [id])
  parentEventId String?
  parentEvent   Event?    @relation("EventToEvent", fields: [parentEventId], references: [id])
  childEvents   Event[]   @relation("EventToEvent")
  
  // Ping relation
  pingId        String?
  ping          Ping?     @relation(fields: [pingId], references: [id])

  // Indexes
  @@index([type])
  @@index([createdAt])
  @@index([userId])
  @@index([teamId])
  @@index([parentEventId])
}

model Ping {
  id            String    @id @default(uuid())
  targetType    String    // person, team
  targetId      String    // user.id or team.id
  message       String?
  status        String    @default("sent") // sent, delivered, failed
  slackSent     Boolean   @default(false)
  fcmSent       Boolean   @default(false)
  n8nTriggered  Boolean   @default(false)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  
  // Relations
  userId        String?
  user          User?     @relation(fields: [userId], references: [id])
  teamId        String?
  team          Team?     @relation(fields: [teamId], references: [id])
  events        Event[]

  // Indexes
  @@index([targetType])
  @@index([targetId])
  @@index([createdAt])
}

model SyncLog {
  id          String    @id @default(uuid())
  entityType  String    // user, team, schedule
  entityId    String
  operation   String    // create, update, delete
  source      String    // APP, SHEETS
  changes     Json      // { before: any, after: any }
  createdAt   DateTime  @default(now())
}